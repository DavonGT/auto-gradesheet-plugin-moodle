<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/gradesheet/db" VERSION="20260312"
    COMMENT="Grade Sheet Generator tables">
    <TABLES>
        <TABLE NAME="local_gradesheet_config" COMMENT="Grading formula config per course">
            <FIELDS>
                <FIELD NAME="id"             TYPE="int"    LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="courseid"       TYPE="int"    LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="quizweight"     TYPE="number" LENGTH="5"  DECIMALS="2" NOTNULL="true" DEFAULT="50"/>
                <FIELD NAME="examweight"     TYPE="number" LENGTH="5"  DECIMALS="2" NOTNULL="true" DEFAULT="50"/>
                <FIELD NAME="activityweight" TYPE="number" LENGTH="5"  DECIMALS="2" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="timecreated"    TYPE="int"    LENGTH="10" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="timemodified"   TYPE="int"    LENGTH="10" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="semester"       TYPE="char"   LENGTH="50" NOTNULL="false" DEFAULT="Second Semester"/>
                <FIELD NAME="schoolyear"     TYPE="char"   LENGTH="20" NOTNULL="false" DEFAULT="2025-2026"/>
                <FIELD NAME="coursenumber"   TYPE="char"   LENGTH="50" NOTNULL="false" DEFAULT=""/>
                <FIELD NAME="descriptive"    TYPE="char"   LENGTH="100" NOTNULL="false" DEFAULT=""/>
                <FIELD NAME="courseandyear"  TYPE="char"   LENGTH="50" NOTNULL="false" DEFAULT=""/>
                <FIELD NAME="schedule"       TYPE="char"   LENGTH="50" NOTNULL="false" DEFAULT=""/>
                <FIELD NAME="units"          TYPE="char"   LENGTH="10" NOTNULL="false" DEFAULT="3"/>
                <FIELD NAME="instructor"     TYPE="char"   LENGTH="100" NOTNULL="false" DEFAULT=""/>
                <FIELD NAME="department_head" TYPE="char"  LENGTH="100" NOTNULL="false" DEFAULT=""/>
                <FIELD NAME="registrar"      TYPE="char"   LENGTH="100" NOTNULL="false" DEFAULT=""/>
                <FIELD NAME="college_dean"   TYPE="char"   LENGTH="100" NOTNULL="false" DEFAULT=""/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>
            <INDEXES>
                <INDEX NAME="courseid" UNIQUE="true" FIELDS="courseid"/>
            </INDEXES>
        </TABLE>
        <TABLE NAME="local_gradesheet_itemmap" COMMENT="Maps grade items to Midterm or Finals">
            <FIELDS>
                <FIELD NAME="id"         TYPE="int"  LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="courseid"   TYPE="int"  LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="gradeitemid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="period"     TYPE="char" LENGTH="10" NOTNULL="true" DEFAULT="finals"/>
                <FIELD NAME="categoryid" TYPE="int" LENGTH="10" NOTNULL="false" DEFAULT="0"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>
            <INDEXES>
                <INDEX NAME="courseid_itemid" UNIQUE="true" FIELDS="courseid, gradeitemid"/>
            </INDEXES>
        </TABLE>
        <TABLE NAME="local_gradesheet_categories" COMMENT="Custom categories for Midterm or Finals">
            <FIELDS>
                <FIELD NAME="id"        TYPE="int"    LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="courseid"  TYPE="int"    LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="name"      TYPE="char"   LENGTH="100" NOTNULL="true"/>
                <FIELD NAME="weight"    TYPE="number" LENGTH="5"  DECIMALS="2" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="sortorder" TYPE="int"    LENGTH="5"  NOTNULL="true" DEFAULT="0"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>
            <INDEXES>
                <INDEX NAME="courseid" UNIQUE="false" FIELDS="courseid"/>
            </INDEXES>
        </TABLE>
    </TABLES>
</XMLDB>